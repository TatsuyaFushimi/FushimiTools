{
  "manifestVersion": 7,
  "id": "com.busoken.drive-asset-browser",
  "name": "Drive Asset Browser",
  "version": "1.0.0",
  "host": {
    "app": "PPRO",
    "minVersion": "22.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "mainPanel",
      "label": { "default": "Drive Asset Browser" },
      "minimumSize": { "width": 280, "height": 400 },
      "preferredDockedSize": { "width": 360, "height": 650 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "https://www.googleapis.com",
        "https://lh3.googleusercontent.com",
        "https://drive.google.com"
      ]
    },
    "localFileSystem": "plugin"
  }
}
